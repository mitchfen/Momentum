@page "/"
@inject AppConfig AppConfig
@inject TodoService TodoService
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Daily Todo</PageTitle>

<div class="momentum-container">
    @if (TodoItems == null)
    {
        <p><em>Loading tasks...</em></p>
    }
    else if (!TodoItems.Any())
    {
        <p>No daily tasks configured.</p>
    }
    else
    {
        <ul class="todo-list">
            @foreach (var item in TodoItems)
            {
                <li class="todo-item @(item.IsCompleted ? "completed" : "")">
                    @if (item.SubTasks.Count == 1)
                    {
                        var subTask = item.SubTasks[0];
                        <div class="task-row">
                            <input type="checkbox" @bind="subTask.IsCompleted" @bind:after="() => SaveSubTaskState(item, subTask)" />
                            <span>@subTask.Text</span>
                        </div>
                    }
                    else
                    {
                        <div class="habit-stack">
                            @if (!string.IsNullOrEmpty(item.DisplayTitle))
                            {
                                <div class="stack-header">
                                    <span class="stack-title">@item.DisplayTitle</span>
                                    <span class="stack-progress">(@item.SubTasks.Count(s => s.IsCompleted)/@item.SubTasks.Count)</span>
                                </div>
                            }
                            else 
                            {
                                <div class="stack-progress-corner">
                                    @item.SubTasks.Count(s => s.IsCompleted)/@item.SubTasks.Count
                                </div>
                            }
                            <ul class="subtask-list @(string.IsNullOrEmpty(item.DisplayTitle) ? "no-header" : "")">
                                @foreach (var subTask in item.SubTasks)
                                {
                                    <li class="subtask-item @(subTask.IsCompleted ? "completed" : "")">
                                        <input type="checkbox" @bind="subTask.IsCompleted" @bind:after="() => SaveSubTaskState(item, subTask)" />
                                        <span>@subTask.Text</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </li>
            }
        </ul>
        <div class="progress-summary">
            <p>Progress: @CompletedCount / @TodoItems.Count</p>
            @if (CompletedCount == TodoItems.Count && TodoItems.Any())
            {
                <p class="all-completed">All tasks completed for today!</p>
            }
        </div>
    }
</div>

@code {
    private List<TodoItem>? TodoItems;
    private int CompletedCount => TodoItems?.Count(item => item.IsCompleted) ?? 0;

    protected override void OnInitialized()
    {
        var today = AppConfig.GetToday();
        TodoItems = AppConfig.DailyTasks.Select(text => {
            string displayTitle = "";
            List<string> subTaskTexts;

            if (text.Contains(':'))
            {
                var parts = text.Split(':', 2);
                displayTitle = parts[0].Trim();
                subTaskTexts = parts[1].Split('+', StringSplitOptions.RemoveEmptyEntries)
                                      .Select(t => t.Trim())
                                      .ToList();
            }
            else
            {
                subTaskTexts = text.Split('+', StringSplitOptions.RemoveEmptyEntries)
                                    .Select(t => t.Trim())
                                    .ToList();
                // For a multi-item stack without a colon, we leave the title empty to avoid redundancy
                displayTitle = subTaskTexts.Count > 1 ? "" : subTaskTexts[0];
            }
            
            var item = new TodoItem 
            { 
                Text = text,
                DisplayTitle = displayTitle,
                SubTasks = subTaskTexts.Select(st => new SubTask 
                { 
                    Text = st,
                    IsCompleted = TodoService.GetSubTaskState(today, text, st)
                }).ToList()
            };
            return item;
        }).ToList();
    }

    private void SaveSubTaskState(TodoItem item, SubTask subTask)
    {
        TodoService.SetSubTaskState(AppConfig.GetToday(), item.Text, subTask.Text, subTask.IsCompleted);
    }
}
